# ============================================================================
# RAINGOD COMFY STUDIO - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your API keys
# Note: .env files should NEVER be committed to version control
# ============================================================================

# LOCAL SERVICES
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_PORT=8188

# CLOUD API KEYS
# ============================================================================
# Sign up: https://cloud.comfy.org
COMFY_CLOUD_API_KEY=your_comfy_cloud_api_key_here

# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Sign up: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Sign up: https://app.suno.ai
SUNO_API_KEY=your_suno_api_key_here

# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Sign up: https://huggingface.co
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Sign up: https://replicate.com
REPLICATE_API_TOKEN=your_replicate_token_here

# BACKEND CONFIGURATION
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# GENERATION DEFAULTS
# ============================================================================
DEFAULT_QUALITY_TIER=standard  # draft, standard, final
DEFAULT_RESOLUTION=768x768    # thumbnail, 512x512, 768x768, 1024x1024, 1536x1536, 2048x2048, 4k
DEFAULT_SAMPLER=dpmpp         # euler, dpmpp, karras, deis, ddim
DEFAULT_STEPS=25              # 15-50 depending on quality tier
DEFAULT_CFG=7.5               # 1-20, guidance scale

# BATCH PROCESSING
# ============================================================================
MAX_BATCH_SIZE=10
BATCH_TIMEOUT=300
QUEUE_MAX_SIZE=100

# CIRCUIT BREAKER
# ============================================================================
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60
CB_SUCCESS_THRESHOLD=2

# RETRY LOGIC
# ============================================================================
MAX_RETRIES=5
BASE_RETRY_DELAY=1  # seconds
MAX_RETRY_DELAY=60  # seconds
RETRY_BACKOFF_FACTOR=2

# CACHE
# ============================================================================
CACHE_TTL=300  # seconds
CACHE_SIZE=1000
ENABLE_DEDUPLICATION=true

# LOGGING
# ============================================================================
LOG_FORMAT=json
LOG_FILE=logs/raingod.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# SECURITY
# ============================================================================
API_KEY_REQUIRED=false
API_KEY=your_internal_api_key_here  # If API_KEY_REQUIRED=true
ALLOWED_ORIGINS=*
